# touchstone project profile. Commit this file so all clones use the same commands.
project_type=python
package_manager=auto
monorepo=false
targets=
git_workflow=git
gitbutler_mcp=false
lint_command=uv run ruff check .
typecheck_command=uv run mypy src tests
build_command=
test_command=uv run pytest
validate_command=uv run ruff check . && uv run mypy src tests && uv run pytest && uv run cortex doctor && uv run cortex doctor --production --json | uv run python -c "import sys,json; r=json.load(sys.stdin); sys.exit(1 if int(r.get('errors',0)) else 0)"
validate_smoke_command=uv run cortex doctor

# Disable mid-branch touchstone script sync on feature branches — Cortex-owned
# scripts (cortex-pr-merged-hook.sh, cortex-journal-wire.sh) diverge from
# upstream touchstone copies and must not be overwritten before open-pr.
TOUCHSTONE_NO_SCRIPT_SYNC=1

# Cortex Protocol § 2 T1.9 — auto-draft `Type: pr-merged` Journal entry
# after every PR squash-merges to main. Hook ships in touchstone v2.4.0+.
# auto = fire when .cortex/ exists and cortex CLI is on PATH (the default).
# off = explicitly disable.
cortex_pr_merged_hook=auto
